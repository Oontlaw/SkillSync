# SkillSync Environment Variables
# Copy this file to .env and fill in your values

SECRET_KEY=skillsync-super-secret-key

# PostgreSQL — replace 'yourpassword' with the password you set during PostgreSQL install
DATABASE_URL=postgresql://postgres:yourpassword@localhost/skillsync

# Discord Bot Token — get this from https://discord.com/developers/applications
DISCORD_TOKEN=your-discord-bot-token-here

# SkillSync API base URL
SKILLSYNC_API=http://localhost:5000/api
