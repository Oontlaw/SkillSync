# ── Flask ──
FLASK_ENV=development
SECRET_KEY=change_this_secret_key
SESSION_COOKIE_SECURE=False

# ── Database ──
# PostgreSQL (default for production)
DATABASE_URL=postgresql://skillsync:skillsync@localhost:5432/skillsync
# SQLite (fallback for local dev — comment out the PostgreSQL line above)
# DATABASE_URL=sqlite:///skillsync.db

# ── Discord Bot ──
DISCORD_TOKEN=your_discord_bot_token_here
COMMAND_PREFIX=!ss

# ── Discord OAuth ──
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_REDIRECT_URI=http://localhost:5000/auth/callback
BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=your_client_id_here&permissions=8&scope=bot

# ── Observer API (used by bot to send data to Flask) ──
API_KEY=change_this_api_key
OBSERVER_BASE_URL=http://localhost:5000

# ── Workspace / Jira (optional) ──
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Fernet key for Jira token encryption at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
JIRA_ENCRYPTION_KEY=

# ── Ngrok (optional tunnel) ──
NGROK_AUTH_TOKEN=
NGROK_DOMAIN=

# ── Slack webhook (optional notifications) ──
SLACK_WEBHOOK_URL=

# ── Flask-Migrate ──
# Set to 1 to skip Alembic migrations and use db.create_all() instead
# FLASK_SKIP_MIGRATIONS=1
